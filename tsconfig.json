{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*",
    ".pi/**/*",
    "tools/**/*",
    "blueprints/**/*",
    "test-apps/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
