{
  "name": "vector",
  "version": "1.0.0",
  "description": "Vector project",
  "private": true,
  "main": "dist/index.js",
  "bin": {
    "vector": "./bin/vector"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "validate": "npx ts-node tools/validation/run.ts",
    "validate:pass": "npx ts-node tools/validation/run.ts --tag pass",
    "validate:fail": "npx ts-node tools/validation/run.ts --tag fail"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.0.0",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  },
  "vitest": {
    "coverage": {
      "provider": "v8",
      "reporter": ["text", "json", "html"],
      "include": ["tools/**/*.ts", "blueprints/**/*.ts", ".pi/**/*.ts"],
      "exclude": ["**/*.test.ts", "**/*.spec.ts", "node_modules", "dist"],
      "lines": 80,
      "statements": 80,
      "branches": 80,
      "functions": 80
    }
  }
}
